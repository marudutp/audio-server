{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"]
    },
    "rootDir": ".",
    "outDir": "./dist"
  },
  "include": [
    "**/*",
    "../shared/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}